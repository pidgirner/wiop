OPENROUTER_IMAGE_MODEL=
OPENROUTER_VIDEO_API_KEY=
OPENROUTER_VIDEO_MODEL=
OPENROUTER_AUDIO_API_KEY=
OPENROUTER_AUDIO_MODEL=
OPENROUTER_POST_API_KEY=
